# Python virtual environment (everyone has their own, not committed to the repo)
.venv/
venv/

# Python cache
__pycache__/
*.pyc

# Program outputs — regenerated on each run, so we don't store the files
# themselves in git, but we KEEP the empty folders (.gitkeep).
debug/*
!debug/.gitkeep
output/*
!output/.gitkeep
input/*
!input/.gitkeep

# SAM checkpoints (large, downloaded separately — see requirements-sam.txt)
models/*.pth
models/*.pt
